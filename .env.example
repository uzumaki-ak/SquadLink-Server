# ─────────────────────────────────────────────
# server
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─────────────────────────────────────────────
# supabase (get these from supabase dashboard → settings → api)
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# database (supabase gives you this under settings → database → connection string)
# use the "transaction" pooler url, not direct, for production
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─────────────────────────────────────────────
# translation (mymemory - register free at mymemory.translated.net to get 50k chars/day)
# leave empty for 5k chars/day anonymous limit
# ─────────────────────────────────────────────
MYMEMORY_EMAIL=your-email@gmail.com

# ─────────────────────────────────────────────
# cors - comma separated list of allowed origins
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,squadlink://app

# ─────────────────────────────────────────────
# jwt (supabase signs tokens with this - copy from supabase dashboard → settings → api → jwt secret)
# ─────────────────────────────────────────────
SUPABASE_JWT_SECRET=your-jwt-secret
